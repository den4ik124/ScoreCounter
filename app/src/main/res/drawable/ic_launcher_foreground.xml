<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Volleyball icon — ball clipped to a circle so seam lines don't bleed outside.
        Center (54,54), radius 32. Seam S-curves are cubics that all pass through
        the center, mirroring the three intersecting great-circle seams of a real ball.
    -->
    <group>
        <clip-path
            android:pathData="M54,22 A32,32 0 0,1 86,54 A32,32 0 0,1 54,86 A32,32 0 0,1 22,54 A32,32 0 0,1 54,22 Z" />

        <!-- Ball body — warm white to read as a light leather panel -->
        <path
            android:fillColor="#FFFDE7"
            android:pathData="M22,22 H86 V86 H22 Z" />

        <!-- Seam 1: horizontal S-curve through equator -->
        <path
            android:fillColor="#00000000"
            android:pathData="M22,54 C36,44 72,64 86,54"
            android:strokeColor="#1565C0"
            android:strokeWidth="2.5" />

        <!-- Seam 2: upper-left → lower-right diagonal S-curve -->
        <path
            android:fillColor="#00000000"
            android:pathData="M38,26 C36,45 72,63 70,82"
            android:strokeColor="#1565C0"
            android:strokeWidth="2.5" />

        <!-- Seam 3: upper-right → lower-left diagonal S-curve -->
        <path
            android:fillColor="#00000000"
            android:pathData="M70,26 C72,45 36,63 38,82"
            android:strokeColor="#1565C0"
            android:strokeWidth="2.5" />

        <!-- Gloss highlight — lens shape in upper-left quadrant -->
        <path
            android:fillColor="#55FFFFFF"
            android:pathData="M36,33 Q44,26 52,33 Q44,37 36,33 Z" />
    </group>

    <!-- Ball outline drawn outside the clip group so it sits on top -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,22 A32,32 0 0,1 86,54 A32,32 0 0,1 54,86 A32,32 0 0,1 22,54 A32,32 0 0,1 54,22 Z"
        android:strokeColor="#0D47A1"
        android:strokeWidth="1.5" />

</vector>
